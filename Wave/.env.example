# Copy to .env.local to point the app at the Django server + MQTT broker.
# Leave BOTH unset to run fully offline on the in-memory MockRepository (default).

# Django REST base (no trailing slash). Use the laptop's LAN IP for a phone demo.
VITE_API_BASE=http://localhost:8000

# Mosquitto WebSocket listener for live "down" delivery (rankings, remediation, peer progress).
VITE_MQTT_URL=ws://localhost:9001
