{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wave/student_summative_results.schema.json",
  "title": "StudentSummativeResults",
  "description": "Final-assessment outcome incl. failed items that drive remediation targeting. Sent UP.",
  "type": "object",
  "required": ["studentLrn", "section", "lessonId", "score", "total", "percent", "passed", "failedItems"],
  "properties": {
    "studentLrn": { "type": "string", "pattern": "^[0-9]{12}$" },
    "section": { "type": "string" },
    "lessonId": { "type": "string", "examples": ["L1"] },
    "score": { "type": "integer", "minimum": 0 },
    "total": { "type": "integer", "default": 20 },
    "percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "passed": { "type": "boolean", "description": "true when score >= 12 (of 20)." },
    "failedItems": {
      "type": "array",
      "description": "Wrong answers; the remediation driver.",
      "items": {
        "type": "object",
        "required": ["questionId", "topicId", "selectedOption", "correctOption"],
        "properties": {
          "questionId": { "type": "string", "examples": ["Q2-1"] },
          "topicId": { "type": "string", "examples": ["L1-T2"] },
          "selectedOption": { "type": "integer", "description": "Index the student picked." },
          "correctOption": { "type": "integer", "description": "Index of the correct answer." }
        }
      }
    }
  }
}
