{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wave/student_progress.schema.json",
  "title": "StudentProgress",
  "description": "Per-topic completion + quiz scores, sent UP (student -> teacher).",
  "type": "object",
  "required": ["studentLrn", "section", "completedTopicIds", "quizAttempts", "quizScores", "summativeScores"],
  "properties": {
    "studentLrn": { "type": "string", "pattern": "^[0-9]{12}$" },
    "section": { "type": "string", "examples": ["Grade 6 - Section Newton"] },
    "completedTopicIds": { "type": "array", "items": { "type": "string" }, "examples": [["L1-T1", "L1-T2"]] },
    "quizAttempts": {
      "type": "object",
      "description": "Keyed by topicId.",
      "additionalProperties": {
        "type": "object",
        "required": ["topicId", "score", "perfectScore", "answers", "completedAt"],
        "properties": {
          "topicId": { "type": "string" },
          "score": { "type": "integer", "minimum": 0 },
          "perfectScore": { "type": "integer", "default": 3 },
          "answers": { "type": "array", "items": { "type": "integer" }, "description": "User-selected option indices." },
          "completedAt": { "type": "string", "format": "date" }
        }
      }
    },
    "quizScores": {
      "type": "object",
      "description": "Keyed by topicId. The per-topic quiz outcome 'sent up'.",
      "additionalProperties": {
        "type": "object",
        "required": ["score", "total", "percent", "passed"],
        "properties": {
          "score": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 1 },
          "percent": { "type": "integer", "minimum": 0, "maximum": 100 },
          "passed": { "type": "boolean", "description": "true when percent >= 70." }
        }
      }
    },
    "summativeScores": {
      "type": "object",
      "description": "Keyed by lessonId.",
      "additionalProperties": {
        "type": "object",
        "required": ["score", "perfectScore", "feedback"],
        "properties": {
          "score": { "type": "integer", "minimum": 0 },
          "perfectScore": { "type": "integer", "default": 20 },
          "feedback": { "type": "string" }
        }
      }
    }
  }
}
