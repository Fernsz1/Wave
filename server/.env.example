# Wave server environment (copy to .env or export in your shell).

# MQTT broker (Mosquitto). Defaults to localhost.
WAVE_BROKER_HOST=127.0.0.1
WAVE_BROKER_PORT=1883

# Google Gemini for AI generation (server-side; the key never reaches the browser).
# Leave GEMINI_API_KEY empty to run the deterministic, catalog-derived fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
